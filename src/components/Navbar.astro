---
const navItems = [
    { label: "Accueil", href: "/#hero" },
    { label: "Stack", href: "/#stack" },
    { label: "À propos", href: "/#about" },
    { label: "Projets", href: "/#projects" },
    { label: "Contact", href: "/#contact" },
];
---

<nav
    class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-bg/70 border-b border-border/50"
>
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-mono font-bold text-lg group">
            <span class="text-accent">&lt;</span>
            <span class="group-hover:text-accent transition-colors">Théo</span>
            <span class="text-accent">/&gt;</span>
        </a>

        <ul class="hidden md:flex items-center gap-8">
            {
                navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            class="text-sm text-text-secondary hover:text-text-primary transition-colors link-underline"
                        >
                            {item.label}
                        </a>
                    </li>
                ))
            }
        </ul>
        <div class="hidden md:flex items-center gap-2">
            <a
                href="/cv.pdf"
                download
                class="inline-flex items-center gap-1.5 px-3 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-bg-card rounded-lg transition-all"
                aria-label="Télécharger mon CV"
            >
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"
                    ></path>
                </svg>
                CV
            </a>

            <a
                href="#contact"
                class="inline-flex items-center px-4 py-2 text-sm
            font-medium bg-accent/10 hover:bg-accent/20 text-accent border
            border-accent/30 rounded-lg transition-all hover:border-accent/50"
            >
                Me contacter
            </a>
        </div>

        <!-- Mobile menu button -->
        <button
            id="mobile-menu-btn"
            class="md:hidden text-text-primary p-2"
            aria-label="Menu"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- Mobile menu -->
    <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-border/50 bg-bg/95"
    >
        <ul class="px-6 py-4 space-y-3">
            {
                navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            class="block text-text-secondary hover:text-text-primary py-1"
                        >
                            {item.label}
                        </a>
                    </li>
                ))
            }
            <li>
                <a
                    href="/cv.pdf"
                    download
                    class="flex items-center gap-2 text-text-secondary hover:text-text-primary py-1"
                >
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"
                        ></path>
                    </svg>
                    Télécharger mon CV
                </a>
            </li>
        </ul>
    </div>

    <script>
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
        menu?.querySelectorAll("a").forEach((a) =>
            a.addEventListener("click", () => menu.classList.add("hidden"))
        );
    </script>
</nav>
