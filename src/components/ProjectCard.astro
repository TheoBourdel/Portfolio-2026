---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import * as simpleIcons from "simple-icons";

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, image, github, demo, status, techStack } =
    project.data;

const getIcon = (iconName: string) => {
    return (simpleIcons as Record<string, { path: string; hex: string }>)[
        iconName
    ];
};
---

<article
    class="group relative flex flex-col bg-bg-card border border-border hover:border-border-hover rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-accent/5"
>
    <!-- IMAGE en grand (paysage 16/10) -->
    <a
        href={`/projects/${project.slug}`}
        class="relative block aspect-[16/10] overflow-hidden bg-bg-soft"
    >
        {
            image ? (
                <Image
                    src={image}
                    alt={title}
                    width={800}
                    height={500}
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    loading="lazy"
                />
            ) : (
                <div class="w-full h-full bg-gradient-to-br from-accent/10 to-bg-soft flex items-center justify-center">
                    <span class="text-text-muted font-mono text-sm">
                        No preview
                    </span>
                </div>
            )
        }

        <!-- Badge "En cours" -->
        {
            status === "in-progress" && (
                <span class="absolute top-3 right-3 px-2.5 py-1 text-xs font-medium bg-yellow-500/20 text-yellow-300 border border-yellow-500/30 rounded-md backdrop-blur-md">
                    En cours
                </span>
            )
        }
    </a>

    <!-- CONTENU -->
    <div class="flex flex-col flex-1 p-5">
        <!-- Titre + flèche au hover -->
        <a
            href={`/projects/${project.slug}`}
            class="flex items-start justify-between gap-3 mb-2"
        >
            <h3
                class="text-lg font-bold text-text-primary group-hover:text-accent transition-colors leading-snug"
            >
                {title}
            </h3>
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="shrink-0 mt-1 text-text-muted group-hover:text-accent transition-all duration-300 -translate-x-1 group-hover:translate-x-0 -translate-y-1 group-hover:translate-y-0"
            >
                <path d="M7 17L17 7M17 7H8M17 7v9"></path>
            </svg>
        </a>

        <!-- Description -->
        <p
            class="text-sm text-text-secondary leading-relaxed line-clamp-2 mb-4"
        >
            {description}
        </p>

        <!-- Footer : stack + liens -->
        <div
            class="flex items-center justify-between gap-3 mt-auto pt-4 border-t border-border/50"
        >
            <!-- Stack icons -->
            <div class="flex items-center gap-1.5">
                {
                    techStack.slice(0, 5).map((iconName) => {
                        const icon = getIcon(iconName);
                        if (!icon) return null;
                        const displayName = iconName
                            .replace(/^si/, "")
                            .replace(/dotjs/i, ".js");
                        return (
                            <div
                                class="w-6 h-6 flex items-center justify-center"
                                title={displayName}
                                style={`--tech-color: #${icon.hex}`}
                            >
                                <svg
                                    role="img"
                                    viewBox="0 0 24 24"
                                    class="w-4 h-4 fill-text-muted hover:fill-[var(--tech-color)] transition-colors"
                                >
                                    <path d={icon.path} />
                                </svg>
                            </div>
                        );
                    })
                }
                {
                    techStack.length > 5 && (
                        <span class="text-xs font-mono text-text-muted ml-1">
                            +{techStack.length - 5}
                        </span>
                    )
                }
            </div>

            <!-- Liens externes -->
            <div class="flex items-center gap-1">
                {
                    github && (
                        <a
                            href={github}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="p-1.5 text-text-muted hover:text-text-primary hover:bg-bg-soft rounded-md transition-all"
                            aria-label="Code source"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                            >
                                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                            </svg>
                        </a>
                    )
                }
                {
                    demo && (
                        <a
                            href={demo}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="p-1.5 text-text-muted hover:text-accent hover:bg-bg-soft rounded-md transition-all"
                            aria-label="Voir la démo"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
                            </svg>
                        </a>
                    )
                }
            </div>
        </div>
    </div>
</article>
