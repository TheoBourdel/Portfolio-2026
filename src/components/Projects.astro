---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

// 🪄 Récupère automatiquement TOUS les projets depuis src/content/projects/
const allProjects = await getCollection("projects");

// Trie par date (plus récent d'abord), avec les "featured" en premier
const projects = allProjects.sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.date.valueOf() - a.data.date.valueOf();
});
---

<section id="projects" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
        <div class="mb-12 flex items-end justify-between flex-wrap gap-4">
            <div>
                <p class="text-accent font-mono text-sm mb-2">// 02</p>
                <h2 class="text-3xl md:text-4xl font-bold">Projets</h2>
                <p class="text-text-secondary mt-2">
                    Une sélection de mes réalisations récentes.
                </p>
            </div>
            <span class="text-text-muted text-sm font-mono">
                {projects.length} projet{projects.length > 1 ? "s" : ""}
            </span>
        </div>

        {
            projects.length === 0 ? (
                <div class="card text-center py-12">
                    <p class="text-text-secondary">
                        Aucun projet pour le moment. Ajoute un fichier{" "}
                        <code class="text-accent">.md</code> dans{" "}
                        <code class="text-accent">src/content/projects/</code>{" "}
                        ✨
                    </p>
                </div>
            ) : (
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {projects.map((project) => (
                        <ProjectCard project={project} />
                    ))}
                </div>
            )
        }
    </div>
</section>
