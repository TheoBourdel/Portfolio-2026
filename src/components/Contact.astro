---
const socials = [
    { name: "GitHub", url: "https://github.com/TheoBourdel", icon: "github" },
    {
        name: "LinkedIn",
        url: "https://www.linkedin.com/in/th%C3%A9o-bourdel-3790a81a4/",
        icon: "linkedin",
    },
];
---

<section id="contact" class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
        <p class="text-accent font-mono text-sm mb-2">// 03</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
            On travaille ensemble ?
        </h2>
        <p class="text-text-secondary text-lg mb-10 max-w-xl mx-auto">
            Une idée de projet, une opportunité, ou simplement envie de discuter
            ? N'hésite pas à m'écrire, je réponds rapidement.
        </p>

        <a
            href="mailto:ton.email@example.com"
            class="inline-flex items-center gap-3 px-8 py-4 bg-accent hover:bg-accent-glow
             text-white font-medium rounded-lg transition-all hover:scale-105 mb-10"
        >
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            bourdeltheo@gmail.com
        </a>

        <div class="flex justify-center gap-6 text-text-muted">
            {
                socials.map((social) => (
                    <a
                        href={social.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-text-primary transition-colors"
                        aria-label={social.name}
                    >
                        {social.name}
                    </a>
                ))
            }
        </div>
    </div>
</section>

<footer class="py-8 px-6 border-t border-border/50 mt-12">
    <div
        class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-text-muted"
    >
        <p>© {new Date().getFullYear()} Théo Bourdel</p>
        <p class="font-mono">
            <a
                href="https://github.com/tonusername/portfolio"
                class="hover:text-text-primary transition-colors"
            >
                Code source
            </a>
        </p>
    </div>
</footer>
