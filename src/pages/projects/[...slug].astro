---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import * as simpleIcons from "simple-icons";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, description, date, image, github, demo, status, techStack } =
    project.data;

const wordCount = project.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const getIcon = (iconName: string) => {
    return (simpleIcons as Record<string, { path: string; hex: string }>)[
        iconName
    ];
};

const statusConfig = {
    completed: { label: "Terminé", dot: "bg-green-500" },
    "in-progress": { label: "En cours", dot: "bg-yellow-500" },
    archived: { label: "Archivé", dot: "bg-zinc-500" },
};
const statusInfo = statusConfig[status];
---

<Layout title={`${title} — Projet`} description={description}>
    <Navbar />

    <div class="fixed top-0 left-0 right-0 h-px z-[60] bg-border/30">
        <div
            id="reading-progress"
            class="h-full bg-accent transition-all duration-100"
            style="width: 0%"
        >
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 pt-28 pb-24">
        <div class="flex items-center justify-between mb-12">
            <a
                href="/#projects"
                class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-text-primary transition-colors"
            >
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path d="M19 12H5M12 19l-7-7 7-7"></path>
                </svg>
                Retour
            </a>

            {
                (github || demo) && (
                    <div class="flex items-center gap-4">
                        {github && (
                            <a
                                href={github}
                                target="_blank"
                                rel="noopener"
                                class="inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-text-primary transition-colors"
                            >
                                <svg
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                >
                                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                                </svg>
                                Code source
                            </a>
                        )}
                        {demo && (
                            <>
                                {github && (
                                    <span class="text-border text-xs">·</span>
                                )}
                                <a
                                    href={demo}
                                    target="_blank"
                                    rel="noopener"
                                    class="inline-flex items-center gap-1.5 text-sm text-accent hover:text-accent-glow transition-colors"
                                >
                                    Voir la démo
                                    <svg
                                        width="12"
                                        height="12"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                    >
                                        <path d="M7 17L17 7M17 7H8M17 7v9" />
                                    </svg>
                                </a>
                            </>
                        )}
                    </div>
                )
            }
        </div>

        <header class="mb-12">
            <h2
                class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] mb-5"
            >
                {title}
            </h2>

            <p
                class="text-lg text-text-secondary leading-relaxed mb-8 max-w-2xl"
            >
                {description}
            </p>

            <div class="grid grid-cols-3 gap-3 mb-8">
                <div class="card !p-4">
                    <div
                        class="flex items-center gap-1.5 text-xs text-text-muted mb-1.5"
                    >
                        <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect x="3" y="4" width="18" height="18" rx="2"
                            ></rect>
                            <path d="M16 2v4M8 2v4M3 10h18"></path>
                        </svg>
                        <span class="font-mono uppercase tracking-wider"
                            >Date</span
                        >
                    </div>
                    <div class="text-sm font-medium text-text-primary">
                        {
                            date.toLocaleDateString("fr-FR", {
                                year: "numeric",
                                month: "short",
                            })
                        }
                    </div>
                </div>

                <div class="card !p-4">
                    <div
                        class="flex items-center gap-1.5 text-xs text-text-muted mb-1.5"
                    >
                        <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 6v6l4 2"></path>
                        </svg>
                        <span class="font-mono uppercase tracking-wider"
                            >Lecture</span
                        >
                    </div>
                    <div class="text-sm font-medium text-text-primary">
                        {readingTime} min
                    </div>
                </div>

                <div class="card !p-4">
                    <div
                        class="flex items-center gap-1.5 text-xs text-text-muted mb-1.5"
                    >
                        <span
                            class={`w-2 h-2 rounded-full ${statusInfo.dot} animate-pulse`}
                        ></span>
                        <span class="font-mono uppercase tracking-wider"
                            >Statut</span
                        >
                    </div>
                    <div class="text-sm font-medium text-text-primary">
                        {statusInfo.label}
                    </div>
                </div>
            </div>

            {
                techStack.length > 0 && (
                    <div class="mb-6">
                        <p class="text-xs font-mono text-text-muted uppercase tracking-wider mb-3">
                            Construit avec
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {techStack.map((iconName) => {
                                const icon = getIcon(iconName);
                                if (!icon) return null;
                                const displayName = iconName
                                    .replace(/^si/, "")
                                    .replace(/dotjs/i, ".js");
                                return (
                                    <div
                                        class="group inline-flex items-center gap-2 px-3 py-1.5 bg-bg-card border border-border hover:border-[var(--tech-color)] rounded-full transition-all hover:-translate-y-0.5"
                                        style={`--tech-color: #${icon.hex}`}
                                    >
                                        <svg
                                            role="img"
                                            viewBox="0 0 24 24"
                                            class="w-3.5 h-3.5 fill-text-secondary group-hover:fill-[var(--tech-color)] transition-colors"
                                        >
                                            <path d={icon.path} />
                                        </svg>
                                        <span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">
                                            {displayName}
                                        </span>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                )
            }
        </header>

        {
            image && (
                <div class="mb-16 rounded-xl overflow-hidden border border-border">
                    <Image
                        src={image}
                        alt={title}
                        width={1800}
                        height={1013}
                        class="w-full h-auto"
                    />
                </div>
            )
        }

        <article>
            <div
                class="prose prose-invert max-w-none
                  prose-headings:text-text-primary prose-headings:font-semibold prose-headings:tracking-tight prose-headings:scroll-mt-24
                  prose-h2:text-2xl prose-h2:mt-16 prose-h2:mb-5
                  prose-h3:text-lg prose-h3:mt-10 prose-h3:mb-3
                  prose-p:text-text-secondary prose-p:leading-[1.75] prose-p:my-5 prose-p:max-w-3xl
                  prose-a:text-accent prose-a:no-underline prose-a:underline-offset-4 hover:prose-a:underline
                  prose-strong:text-text-primary prose-strong:font-semibold
                  prose-code:text-accent prose-code:bg-bg-card prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-[0.875em] prose-code:font-medium prose-code:before:content-[''] prose-code:after:content-['']
                  prose-pre:bg-bg-card prose-pre:border prose-pre:border-border prose-pre:rounded-lg prose-pre:my-7
                  prose-img:rounded-lg prose-img:border prose-img:border-border prose-img:my-8
                  prose-li:text-text-secondary prose-li:my-1.5 prose-li:leading-[1.75]
                  prose-ul:my-5 prose-ol:my-5 prose-ul:max-w-3xl prose-ol:max-w-3xl
                  prose-blockquote:border-l-2 prose-blockquote:border-accent prose-blockquote:bg-transparent prose-blockquote:px-4 prose-blockquote:py-0 prose-blockquote:not-italic prose-blockquote:text-text-secondary prose-blockquote:font-normal prose-blockquote:max-w-3xl
                  prose-hr:border-border prose-hr:my-12"
            >
                <Content />
            </div>
        </article>
    </div>
</Layout>

<script>
    const progress = document.getElementById("reading-progress");
    const updateProgress = () => {
        const scrolled =
            (window.scrollY /
                (document.body.scrollHeight - window.innerHeight)) *
            100;
        if (progress) progress.style.width = Math.min(scrolled, 100) + "%";
    };
    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
</script>
